    "caption": "DB Notebook",
    "content": "\\about\nCREATE DATABASE customer_project; \nSELECT * FROM shopping_data LIMIT 20\nSELECT \n    gender,\n    SUM(`purchase_amount_(usd)`) AS total_revenue\nFROM \n    shopping_data\nGROUP BY \n    gender;\n\nSELECT \n    customer_id,\n    gender,\n    discount_applied,\n    `purchase_amount_(usd)` AS purchase_amount,\n    CASE \n        WHEN discount_applied = 'Yes' \n             AND `purchase_amount_(usd)` > (\n                 SELECT AVG(`purchase_amount_(usd)`) FROM shopping_data\n             )\n        THEN 'Yes'\n        ELSE 'No'\n    END AS above_avg_after_discount\nFROM \n    shopping_data;\nSELECT \n    item_purchased,\n    AVG(review_rating) AS avg_rating\nFROM \n    shopping_data\nGROUP BY \n    item_purchased\nORDER BY \n    avg_rating DESC\nLIMIT 5;\nSELECT \n    shipping_type,\n    AVG(`purchase_amount_(usd)`) AS avg_purchase_amount\nFROM \n    shopping_data\nWHERE \n    shipping_type IN ('Standard', 'Express')\nGROUP BY \n    shipping_type;\nSELECT \n    subscription_status,\n    AVG(`purchase_amount_(usd)`) AS avg_spend,\n    SUM(`purchase_amount_(usd)`) AS total_revenue,\n    COUNT(*) AS total_customers\nFROM \n    shopping_data\nGROUP BY \n    subscription_status;\n\nSELECT \n    item_purchased,\n    COUNT(*) AS total_purchases,\n    SUM(CASE WHEN discount_applied = 'Yes' THEN 1 ELSE 0 END) AS discounted_purchases,\n    CONCAT(\n        ROUND(\n            (SUM(CASE WHEN discount_applied = 'Yes' THEN 1 ELSE 0 END) * 100.0 / COUNT(*)), \n        2\n        ), \n    '%') AS discount_percentage\nFROM \n    shopping_data\nGROUP BY \n    item_purchased\nORDER BY \n    (SUM(CASE WHEN discount_applied = 'Yes' THEN 1 ELSE 0 END) * 100.0 / COUNT(*)) DESC\nLIMIT 5;\nSELECT \n    customer_id,\n    previous_purchases,\n    CASE \n        WHEN previous_purchases = 0 THEN 'New'\n        WHEN previous_purchases BETWEEN 1 AND 10 THEN 'Returning'\n        ELSE 'Loyal'\n    END AS customer_segment\nFROM \n    shopping_data;\nSELECT \n    category,\n    item_purchased,\n    total_purchases\nFROM (\n    SELECT \n        category,\n        item_purchased,\n        COUNT(*) AS total_purchases,\n        RANK() OVER (\n            PARTITION BY category \n            ORDER BY COUNT(*) DESC\n        ) AS rank_in_category\n    FROM \n        shopping_data\n    GROUP BY \n        category, item_purchased\n) ranked\nWHERE \n    rank_in_category <= 3;\n\nSELECT \n    CASE \n        WHEN previous_purchases > 5 THEN 'Repeat Buyer'\n        ELSE 'Other'\n    END AS customer_type,\n    ROUND(100.0 * AVG(CASE WHEN subscription_status = 'Yes' THEN 1 ELSE 0 END), 2) AS subscription_rate_percentage\nFROM \n    customer_analysis.shopping_data\nGROUP BY \n    customer_type;\nSELECT \n    CASE\n        WHEN age >= 18 AND age < 26 THEN 'Young Adult'\n        WHEN age >= 26 AND age < 46 THEN 'Adult'\n        WHEN age >= 46 AND age < 61 THEN 'Mid Age'\n        WHEN age >= 61 AND age < 71 THEN 'Senior Citizen'\n        ELSE 'Other'\n    END AS age_group,\n    SUM(`purchase_amount_(usd)`) AS total_revenue,\n    ROUND(100.0 * SUM(`purchase_amount_(usd)`) / (SELECT SUM(`purchase_amount_(usd)`) FROM shopping_data), 2) AS revenue_percentage\nFROM \n    shopping_data\nGROUP BY \n    CASE\n        WHEN age >= 18 AND age < 26 THEN 'Young Adult'\n        WHEN age >= 26 AND age < 46 THEN 'Adult'\n        WHEN age >= 46 AND age < 61 THEN 'Mid Age'\n        WHEN age >= 61 AND age < 71 THEN 'Senior Citizen'\n        ELSE 'Other'\n    END\nORDER BY \n    age_group;\n\n",
